<% content_for :title, "新規登録" %>

<div class="container py-5">
  <div class="mx-auto" style="max-width: 520px;">
    <div class="mb-4">
      <%= link_to "いつもの交通費メモ", root_path, class: "text-decoration-none fw-bold text-dark" %>
    </div>

    <h1 class="h3 fw-bold mb-2">新規登録</h1>
    <p class="text-secondary mb-4">名前とあいことばで、交通費メモ用のアカウントを作成します。</p>

    <% if @user.errors.any? %>
      <div class="alert alert-danger" role="alert">
        <p class="fw-bold mb-2">入力内容を確認してください</p>
        <ul class="mb-0">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, local: true do |form| %>
      <div class="mb-3">
        <%= form.label :name, "名前", class: "form-label" %>
        <%= form.text_field :name, class: "form-control", autocomplete: "name" %>
      </div>

      <div class="mb-3">
        <%= form.label :password, "あいことば", class: "form-label" %>
        <%= form.password_field :password, class: "form-control", autocomplete: "new-password" %>
        <div class="form-text">8文字以上で入力してください。</div>
      </div>

      <div class="mb-4">
        <%= form.label :password_confirmation, "あいことば確認", class: "form-label" %>
        <%= form.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
      </div>

      <div class="d-grid gap-3">
        <%= form.submit "登録する", class: "btn btn-primary btn-lg" %>
        <%= link_to "ログイン画面へ", login_path, class: "btn btn-outline-primary" %>
      </div>
    <% end %>
  </div>
</div>
