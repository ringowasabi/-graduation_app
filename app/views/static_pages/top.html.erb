<% content_for(:title, "いつもの交通費メモ") %>

<header class="border-bottom bg-white">
  <nav class="navbar navbar-expand-lg container py-3">
    <%= link_to "いつもの交通費メモ", root_path, class: "navbar-brand fw-bold" %>
    <div class="ms-auto d-flex gap-2">
      <%= link_to "ログイン", login_path, class: "btn btn-outline-primary" %>
      <%= link_to "新規登録", signup_path, class: "btn btn-primary" %>
    </div>
  </nav>
</header>

<main>
  <section class="py-5 py-lg-6 bg-light">
    <div class="container">
      <div class="row align-items-center g-5">
        <div class="col-lg-7">
          <p class="text-primary fw-semibold mb-2">外回り営業の交通費を、すぐ見返せる。</p>
          <h1 class="display-5 fw-bold lh-sm mb-3">いつもの訪問先の交通費を、もう毎回調べ直さない。</h1>
          <p class="lead text-secondary mb-4">
            保険営業マンなど外回りでよく訪問する顧客先や活動先の交通費を登録し、
            片道料金と往復料金をすぐ確認できるアプリです。
          </p>
          <div class="d-flex flex-column flex-sm-row gap-3">
            <%= link_to "交通費メモをはじめる", signup_path, class: "btn btn-primary btn-lg" %>
            <%= link_to "ログインする", login_path, class: "btn btn-outline-primary btn-lg" %>
          </div>
        </div>
        <div class="col-lg-5">
          <div class="border rounded bg-white p-4 shadow-sm">
            <p class="fw-bold mb-3">登録できる交通費メモ</p>
            <dl class="row mb-0">
              <dt class="col-4 text-secondary">訪問先</dt>
              <dd class="col-8">活動先A</dd>
              <dt class="col-4 text-secondary">出発地</dt>
              <dd class="col-8">新宿</dd>
              <dt class="col-4 text-secondary">到着地</dt>
              <dd class="col-8">渋谷</dd>
              <dt class="col-4 text-secondary">片道料金</dt>
              <dd class="col-8">450円</dd>
              <dt class="col-4 text-secondary">往復料金</dt>
              <dd class="col-8 fw-bold text-primary">900円</dd>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-5">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-4">
          <div class="h-100 border rounded p-4">
            <h2 class="h5 fw-bold">交通費だけを保存</h2>
            <p class="text-secondary mb-0">訪問先、出発地、到着地、片道料金を交通費メモとして管理できます。</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="h-100 border rounded p-4">
            <h2 class="h5 fw-bold">往復料金を自動表示</h2>
            <p class="text-secondary mb-0">片道料金を登録すると、往復料金をすぐ確認できます。</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="h-100 border rounded p-4">
            <h2 class="h5 fw-bold">営業前に前向きに</h2>
            <p class="text-secondary mb-0">登録完了後に応援メッセージを表示し、外回り前の気持ちを支えます。</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<footer class="border-top py-4">
  <div class="container d-flex flex-column flex-sm-row justify-content-between gap-2">
    <small class="text-secondary">&copy; 2026 いつもの交通費メモ</small>
    <div class="d-flex gap-3">
      <%= link_to "利用規約", "#", class: "link-secondary link-underline-opacity-0" %>
      <%= link_to "プライバシーポリシー", "#", class: "link-secondary link-underline-opacity-0" %>
    </div>
  </div>
</footer>
