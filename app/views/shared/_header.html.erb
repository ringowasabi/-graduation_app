<header class="border-bottom bg-white">
  <nav class="navbar navbar-expand-lg container py-3">
    <%= link_to "いつもの交通費メモ", root_path, class: "navbar-brand fw-bold" %>

    <div class="ms-auto d-flex gap-2">
      <% if logged_in? %>
        <%= link_to "交通費メモ一覧", transportation_memos_path, class: "btn btn-outline-primary" %>
        <%= link_to "交通費メモ登録", new_transportation_memo_path, class: "btn btn-outline-primary" %>
        <%= link_to "訪問先登録", new_destination_path, class: "btn btn-outline-primary" %>
        <%= link_to "ログアウト", logout_path, class: "btn btn-primary", data: { turbo_method: :delete } %>
      <% else %>
        <%= link_to "ログイン", login_path, class: "btn btn-outline-primary" %>
        <%= link_to "新規登録", signup_path, class: "btn btn-primary" %>
      <% end %>
    </div>
  </nav>
</header>
