<% content_for :title, "登録完了" %>

<%= render "shared/header" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="completion-message-card p-5 text-center mb-4" role="img" aria-label="登録完了！今日の営業もがんばりましょう！">
        <span class="completion-message-card__label">交通費メモ登録完了</span>
        <h1 class="display-6 fw-bold mb-3">登録完了！今日の営業もがんばりましょう！</h1>
        <p class="mb-0">外回り前にすぐ確認できる交通費メモを保存しました。</p>
      </div>

      <div class="d-flex justify-content-center gap-3">
        <%= link_to "一覧へ戻る", transportation_memos_path, class: "btn btn-outline-primary" %>
        <%= link_to "続けて登録する", new_transportation_memo_path, class: "btn btn-primary" %>
      </div>
    </div>
  </div>
</div>
