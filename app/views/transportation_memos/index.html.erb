<% content_for :title, "交通費メモ一覧" %>

<%= render "shared/header" %>

<div class="container py-5">
  <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
    <div>
      <p class="text-primary fw-bold mb-1">交通費メモ</p>
      <h1 class="h3 fw-bold mb-0">交通費メモ一覧</h1>
    </div>
    <%= link_to "交通費メモを登録", new_transportation_memo_path, class: "btn btn-primary" %>
  </div>

  <% if @transportation_memos.any? %>
    <div class="table-responsive border rounded-3 bg-white d-none d-md-block">
      <table class="table align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>訪問先</th>
            <th>出発地</th>
            <th>到着地</th>
            <th class="text-end">片道料金</th>
            <th class="text-end">往復料金</th>
            <th class="text-end">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @transportation_memos.each do |memo| %>
            <tr>
              <td class="fw-bold"><%= memo.destination.name %></td>
              <td><%= memo.departure_place %></td>
              <td><%= memo.arrival_place %></td>
              <td class="text-end"><%= number_to_currency(memo.one_way_fare, unit: "円", precision: 0, format: "%n%u") %></td>
              <td class="text-end"><%= number_to_currency(memo.round_trip_fare, unit: "円", precision: 0, format: "%n%u") %></td>
              <td class="text-end">
                <div class="d-inline-flex gap-2">
                  <%= link_to "詳細", transportation_memo_path(memo), class: "btn btn-sm btn-outline-primary" %>
                  <%= link_to "編集", edit_transportation_memo_path(memo), class: "btn btn-sm btn-outline-secondary" %>
                  <%= button_to "削除", transportation_memo_path(memo), method: :delete, class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: "交通費メモを削除しますか？" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="d-grid gap-3 d-md-none">
      <% @transportation_memos.each do |memo| %>
        <div class="border rounded-3 p-3 bg-white">
          <div class="d-flex justify-content-between gap-3 mb-3">
            <div>
              <p class="text-secondary small mb-1">訪問先</p>
              <h2 class="h5 fw-bold mb-0"><%= memo.destination.name %></h2>
            </div>
            <div class="text-end">
              <p class="text-secondary small mb-1">往復料金</p>
              <p class="h5 fw-bold text-primary mb-0"><%= number_to_currency(memo.round_trip_fare, unit: "円", precision: 0, format: "%n%u") %></p>
            </div>
          </div>

          <dl class="row mb-3">
            <dt class="col-5 text-secondary">出発地</dt>
            <dd class="col-7 mb-2"><%= memo.departure_place %></dd>
            <dt class="col-5 text-secondary">到着地</dt>
            <dd class="col-7 mb-2"><%= memo.arrival_place %></dd>
            <dt class="col-5 text-secondary">片道料金</dt>
            <dd class="col-7 mb-0"><%= number_to_currency(memo.one_way_fare, unit: "円", precision: 0, format: "%n%u") %></dd>
          </dl>

          <div class="d-grid gap-2">
            <%= link_to "詳細", transportation_memo_path(memo), class: "btn btn-outline-primary" %>
            <%= link_to "編集", edit_transportation_memo_path(memo), class: "btn btn-outline-secondary" %>
            <%= button_to "削除", transportation_memo_path(memo), method: :delete, class: "btn btn-outline-danger w-100", data: { turbo_confirm: "交通費メモを削除しますか？" } %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="border rounded-3 p-4 bg-light">
      <p class="mb-2 fw-bold">交通費メモはまだ登録されていません。</p>
      <p class="text-secondary mb-3">訪問先、出発地、到着地、片道料金を登録して、外回り前にすぐ確認できるようにしましょう。</p>
      <%= link_to "交通費メモを登録", new_transportation_memo_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
