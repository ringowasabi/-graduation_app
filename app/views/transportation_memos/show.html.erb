<% content_for :title, "交通費メモ詳細" %>

<%= render "shared/header" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
        <div>
          <p class="text-primary fw-bold mb-1">交通費メモ</p>
          <h1 class="h3 fw-bold mb-0">交通費メモ詳細</h1>
        </div>
        <%= link_to "一覧へ戻る", transportation_memos_path, class: "btn btn-outline-secondary" %>
      </div>

      <div class="border rounded-3 p-4 bg-white mb-4">
        <dl class="row mb-0">
          <dt class="col-sm-4 text-secondary">訪問先</dt>
          <dd class="col-sm-8 fw-bold"><%= @transportation_memo.destination.name %></dd>

          <dt class="col-sm-4 text-secondary">出発地</dt>
          <dd class="col-sm-8"><%= @transportation_memo.departure_place %></dd>

          <dt class="col-sm-4 text-secondary">到着地</dt>
          <dd class="col-sm-8"><%= @transportation_memo.arrival_place %></dd>

          <dt class="col-sm-4 text-secondary">片道料金</dt>
          <dd class="col-sm-8"><%= number_to_currency(@transportation_memo.one_way_fare, unit: "円", precision: 0, format: "%n%u") %></dd>

          <dt class="col-sm-4 text-secondary">往復料金</dt>
          <dd class="col-sm-8 fw-bold text-primary"><%= number_to_currency(@transportation_memo.round_trip_fare, unit: "円", precision: 0, format: "%n%u") %></dd>
        </dl>
      </div>

      <div class="d-grid d-sm-flex gap-2">
        <%= link_to "編集", edit_transportation_memo_path(@transportation_memo), class: "btn btn-primary" %>
        <%= link_to "削除", transportation_memo_path(@transportation_memo), class: "btn btn-outline-danger", data: { turbo_method: :delete, turbo_confirm: "交通費メモを削除しますか？" } %>
      </div>
    </div>
  </div>
</div>
