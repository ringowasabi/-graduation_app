# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Ignore bundler config.
/.bundle
/vendor/bundle

# Ignore environment files.
/.env*

# Ignore Rails credentials key.
/config/master.key
/config/credentials/*.key

# Ignore log and temp files.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids
!/tmp/pids/.keep

# Ignore uploaded files in development.
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Ignore built assets and node modules.
/node_modules
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets

# Ignore local OS/editor files.
.DS_Store
